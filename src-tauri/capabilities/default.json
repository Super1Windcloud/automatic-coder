{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "updater",
    "code_language_selector",
    "custom_openai_selector"
  ],
  "allowlist": {
    "all": true
  },
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "process:default",
    "process:allow-restart",
    "opener:default",
    "notification:default",
    "log:default"
  ],
  "capabilities": []
}
