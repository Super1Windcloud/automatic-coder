{
  "name": "interview-coder",
  "private": true,
  "version": "1.1.5",
  "author": {
    "name": "superwindcloud",
    "email": "ss1178933440@gmail.com"
  },
  "homepage": "https://github.com/Super1WindCloud",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "taze": "npx taze latest  -w",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "td": "tauri dev",
    "tb": "pnpm tsx scripts/tauri-build.ts",
    "icon": "tauri icon  app-icon.png",
    "prepare": "husky",
    "lint": "eslint  src --fix && cd src-tauri && cargo check",
    "clean": "cd src-tauri && cargo clean",
    "format": "prettier --write src && cd src-tauri &&  cargo fmt",
    "build:select": "vite build --config vite.select.config.ts",
    "custom": "pnpm build && pnpm build:select && pnpm build:activation && pnpm build:openai && pnpm build:host",
    "sign": "pnpm tauri signer generate -w ~/.tauri/interview_code.key",
    "release": "cd src-tauri && cargo build --release",
    "build:activation": "vite build --config vite.activation.config.ts",
    "build:openai": "vite build --config vite.openai.config.ts",
    "build:host": "vite build --config vite.host.config.ts",
    "migrate": "biome  migrate prettier  --write && biome migrate eslint --write",
    "fix": "biome check --fix",
    "pnpm:fix": "pnpm fix",
    "up-rust-deps": "cd src-tauri && cargo upgrade && cargo update",
    "publish:new": "pnpm tsx scripts/release.ts",
    "publish:new:windows": "pnpm tsx scripts/release.ts windows",
    "publish:new:macos": "pnpm tsx scripts/release.ts macos"
  },
  "dependencies": {
    "@lexical/markdown": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-log": "~2",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "@uiw/react-markdown-preview": "^5.1.5",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "form-data": "^4.0.5",
    "lexical": "^0.42.0",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-use": "^17.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "biome": "^0.3.3",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "process": "^0.11.10",
    "rimraf": "^6.1.3",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1"
  }
}
