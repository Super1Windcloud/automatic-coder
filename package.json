{
  "name": "interview-coder",
  "private": true,
  "version": "0.1.3",
  "author": {
    "name": "superwindcloud",
    "email": "ss1178933440@gmail.com"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "taze": "npx taze latest  -w",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "td": "tauri dev",
    "tb": "tauri build &&  npx rimraf  bundle &&  mv src-tauri/target/release/bundle   ./bundle",
    "icon": "tauri icon  app-icon.png",
    "prepare": "husky",
    "lint": "eslint  src --fix && cd src-tauri && cargo check",
    "clean": "cd src-tauri && cargo clean && cargo update",
    "format": "prettier --write src && cd src-tauri &&  cargo fmt",
    "build:select": "vite build --config vite.select.config.ts",
    "custom": "pnpm build && pnpm build:select && pnpm build:activation",
    "sign": "pnpm tauri signer generate -w ~/.tauri/interview_code.key",
    "release": "cd src-tauri && cargo build --release",
    "build:activation": "vite build --config vite.activation.config.ts",
    "migrate": "biome  migrate prettier  --write && biome migrate eslint --write",
    "fix": "biome check --fix",
    "pnpm:fix": "pnpm fix"
  },
  "dependencies": {
    "@lexical/markdown": "^0.38.2",
    "@lexical/react": "^0.38.2",
    "@lexical/rich-text": "^0.38.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.7",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.9.0",
    "@uiw/react-markdown-preview": "^5.1.5",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "form-data": "^4.0.4",
    "lexical": "^0.38.2",
    "lucide-react": "^0.553.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "react-use": "^17.6.0",
    "sonner": "^2.0.7",
